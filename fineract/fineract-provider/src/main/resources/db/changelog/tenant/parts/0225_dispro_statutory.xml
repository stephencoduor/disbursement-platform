<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet author="dispro" id="dispro-statutory-1-paye-band">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="m_dispro_paye_band"/></not></preConditions>
        <createTable tableName="m_dispro_paye_band">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="country_code" type="VARCHAR(2)" defaultValue="ZM"><constraints nullable="false"/></column>
            <column name="effective_from" type="DATE"><constraints nullable="false"/></column>
            <column name="lower_bound_minor" type="BIGINT"><constraints nullable="false"/></column>
            <column name="upper_bound_minor" type="BIGINT"/>
            <column name="rate_bps" type="INT"><constraints nullable="false"/></column>
            <column name="currency" type="VARCHAR(3)" defaultValue="ZMW"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet author="dispro" id="dispro-statutory-2-rates">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="m_dispro_statutory_rate"/></not></preConditions>
        <createTable tableName="m_dispro_statutory_rate">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="country_code" type="VARCHAR(2)" defaultValue="ZM"><constraints nullable="false"/></column>
            <column name="scheme" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="party" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="rate_bps" type="INT"><constraints nullable="false"/></column>
            <column name="ceiling_minor" type="BIGINT"/>
            <column name="effective_from" type="DATE"><constraints nullable="false"/></column>
            <column name="currency" type="VARCHAR(3)" defaultValue="ZMW"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet author="dispro" id="dispro-statutory-3-calculations">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="m_dispro_statutory_calculation"/></not></preConditions>
        <createTable tableName="m_dispro_statutory_calculation">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="client_id" type="BIGINT"/>
            <column name="period_month" type="VARCHAR(7)"><constraints nullable="false"/></column>
            <column name="gross_minor" type="BIGINT"><constraints nullable="false"/></column>
            <column name="paye_minor" type="BIGINT"><constraints nullable="false"/></column>
            <column name="napsa_ee_minor" type="BIGINT"><constraints nullable="false"/></column>
            <column name="napsa_er_minor" type="BIGINT"><constraints nullable="false"/></column>
            <column name="nhima_ee_minor" type="BIGINT"><constraints nullable="false"/></column>
            <column name="nhima_er_minor" type="BIGINT"><constraints nullable="false"/></column>
            <column name="sdl_minor" type="BIGINT"><constraints nullable="false"/></column>
            <column name="net_minor" type="BIGINT"><constraints nullable="false"/></column>
            <column name="calculated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="calculation_engine_version" type="VARCHAR(50)" defaultValue="dispro-statutory-v1-2025"/>
        </createTable>
    </changeSet>

    <changeSet author="dispro" id="dispro-statutory-4-seed-paye-bands">
        <preConditions onFail="MARK_RAN"><sqlCheck expectedResult="0">SELECT COUNT(*) FROM m_dispro_paye_band WHERE country_code = 'ZM' AND effective_from = '2025-01-01'</sqlCheck></preConditions>
        <insert tableName="m_dispro_paye_band"><column name="country_code" value="ZM"/><column name="effective_from" valueDate="2025-01-01"/><column name="lower_bound_minor" valueNumeric="0"/><column name="upper_bound_minor" valueNumeric="510000"/><column name="rate_bps" valueNumeric="0"/></insert>
        <insert tableName="m_dispro_paye_band"><column name="country_code" value="ZM"/><column name="effective_from" valueDate="2025-01-01"/><column name="lower_bound_minor" valueNumeric="510001"/><column name="upper_bound_minor" valueNumeric="710000"/><column name="rate_bps" valueNumeric="2000"/></insert>
        <insert tableName="m_dispro_paye_band"><column name="country_code" value="ZM"/><column name="effective_from" valueDate="2025-01-01"/><column name="lower_bound_minor" valueNumeric="710001"/><column name="upper_bound_minor" valueNumeric="920000"/><column name="rate_bps" valueNumeric="3000"/></insert>
        <insert tableName="m_dispro_paye_band"><column name="country_code" value="ZM"/><column name="effective_from" valueDate="2025-01-01"/><column name="lower_bound_minor" valueNumeric="920001"/><column name="rate_bps" valueNumeric="3700"/></insert>
    </changeSet>

    <changeSet author="dispro" id="dispro-statutory-5-seed-rates">
        <preConditions onFail="MARK_RAN"><sqlCheck expectedResult="0">SELECT COUNT(*) FROM m_dispro_statutory_rate WHERE country_code = 'ZM' AND effective_from = '2025-01-01'</sqlCheck></preConditions>
        <insert tableName="m_dispro_statutory_rate"><column name="country_code" value="ZM"/><column name="scheme" value="NAPSA"/><column name="party" value="EMPLOYEE"/><column name="rate_bps" valueNumeric="500"/><column name="ceiling_minor" valueNumeric="170820"/><column name="effective_from" valueDate="2025-01-01"/></insert>
        <insert tableName="m_dispro_statutory_rate"><column name="country_code" value="ZM"/><column name="scheme" value="NAPSA"/><column name="party" value="EMPLOYER"/><column name="rate_bps" valueNumeric="500"/><column name="ceiling_minor" valueNumeric="170820"/><column name="effective_from" valueDate="2025-01-01"/></insert>
        <insert tableName="m_dispro_statutory_rate"><column name="country_code" value="ZM"/><column name="scheme" value="NHIMA"/><column name="party" value="EMPLOYEE"/><column name="rate_bps" valueNumeric="100"/><column name="effective_from" valueDate="2025-01-01"/></insert>
        <insert tableName="m_dispro_statutory_rate"><column name="country_code" value="ZM"/><column name="scheme" value="NHIMA"/><column name="party" value="EMPLOYER"/><column name="rate_bps" valueNumeric="100"/><column name="effective_from" valueDate="2025-01-01"/></insert>
        <insert tableName="m_dispro_statutory_rate"><column name="country_code" value="ZM"/><column name="scheme" value="SDL"/><column name="party" value="EMPLOYER"/><column name="rate_bps" valueNumeric="50"/><column name="effective_from" valueDate="2025-01-01"/></insert>
    </changeSet>

</databaseChangeLog>